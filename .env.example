OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSION=1536
DEFAULT_LLM_PROVIDER=openai

DATABASE_URL=postgresql://relay:relay_secret@postgres:5432/relay_ops
REDIS_URL=redis://:redis_secret@redis:6379/0
CELERY_BROKER_URL=redis://:redis_secret@redis:6379/1

KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_ISSUER=http://localhost:8080
# With make tls-up use: KEYCLOAK_ISSUER=https://auth.acme-relay.local
KEYCLOAK_REALM=acme
KEYCLOAK_CLIENT_ID=relay-backend
KEYCLOAK_FRONTEND_CLIENT_ID=relay-frontend
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

LANGFUSE_PUBLIC_KEY=pk-lf-relay-local-public
LANGFUSE_SECRET_KEY=sk-lf-relay-local-secret
LANGFUSE_HOST=http://langfuse:3000
LANGFUSE_UI_URL=http://localhost:3001
LANGFUSE_PROJECT_ID=relay-ops
ENABLE_LANGFUSE=true

# Optional LangSmith (off by default — Relay uses Langfuse for traces)
ENABLE_LANGSMITH=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=relay-agent
LANGSMITH_ORG_ID=
LANGSMITH_UI_URL=https://smith.langchain.com

GLITCHTIP_DSN=
GLITCHTIP_UI_URL=http://localhost:8001
ENABLE_GLITCHTIP=true

GRAFANA_UI_URL=http://localhost:3002

ENABLE_MCP_AGENT_TOOLS=true
MCP_DOMAIN_URL=http://mcp-domain:8090
MCP_FILESYSTEM_URL=http://mcp-filesystem:8091
MCP_POSTGRES_URL=http://mcp-postgres:8092
MCP_CONNECT_TIMEOUT_SECONDS=10
MCP_SSE_READ_TIMEOUT_SECONDS=120

CORS_ORIGINS=http://localhost:5173
FRONTEND_URL=http://localhost:5173
# With make tls-up: FRONTEND_URL=https://acme-relay.local
# CORS_ORIGINS=https://acme-relay.local,http://localhost:5173
GRAFANA_ADMIN_PASSWORD=admin
