# Relay local HTTPS edge (Caddy + mkcert)
#
# Hosts (add to /etc/hosts → 127.0.0.1):
#   acme-relay.local api.acme-relay.local auth.acme-relay.local
#   glitchtip.local langfuse.local grafana.local
#
# Certs are mounted from infra/caddy/.certs (generated by scripts/setup-local-tls.sh).

{
	auto_https disable_redirects
}

(tls_local) {
	tls /certs/relay-local.pem /certs/relay-local-key.pem
}

acme-relay.local {
	import tls_local
	encode gzip
	reverse_proxy web:80
}

api.acme-relay.local {
	import tls_local
	encode gzip
	reverse_proxy api:8000
}

auth.acme-relay.local {
	import tls_local
	encode gzip
	reverse_proxy keycloak:8080
}

glitchtip.local {
	import tls_local
	encode gzip
	reverse_proxy glitchtip:8000
}

langfuse.local {
	import tls_local
	encode gzip
	reverse_proxy langfuse:3000
}

grafana.local {
	import tls_local
	encode gzip
	reverse_proxy grafana:3000
}

# HTTP → HTTPS for the desk and auth (browsers often hit :80 first)
http://acme-relay.local, http://api.acme-relay.local, http://auth.acme-relay.local, http://glitchtip.local, http://langfuse.local, http://grafana.local {
	redir https://{host}{uri} permanent
}
