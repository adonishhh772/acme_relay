{
  "realm": "acme",
  "enabled": true,
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,
  "otpPolicyType": "totp",
  "otpPolicyAlgorithm": "HmacSHA1",
  "otpPolicyDigits": 6,
  "otpPolicyPeriod": 30,
  "otpSupportedApplications": ["totpAppFreeOTPName", "totpAppGoogleName"],
  "roles": {
    "realm": [
      { "name": "sales_user", "description": "Read customer and case data" },
      { "name": "support_user", "description": "Read and propose case updates" },
      { "name": "operations_user", "description": "Operations department queue and cross-functional actions" },
      { "name": "admin", "description": "Full access including approvals and governance" },
      { "name": "offline_access" },
      { "name": "uma_authorization" },
      {
        "name": "default-roles-acme",
        "composite": true,
        "composites": { "realm": ["offline_access", "uma_authorization"] }
      }
    ]
  },
  "defaultRole": { "name": "default-roles-acme" },
  "requiredActions": [
    {
      "alias": "CONFIGURE_TOTP",
      "name": "Configure OTP",
      "providerId": "CONFIGURE_TOTP",
      "enabled": true,
      "defaultAction": false,
      "priority": 10,
      "config": {}
    }
  ],
  "clients": [
    {
      "clientId": "relay-frontend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://127.0.0.1:5173/*",
        "https://acme-relay.local/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://127.0.0.1:5173",
        "https://acme-relay.local",
        "+"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://localhost:5173/*##https://acme-relay.local/*"
      }
    },
    {
      "clientId": "relay-backend",
      "enabled": true,
      "publicClient": true,
      "directAccessGrantsEnabled": true,
      "standardFlowEnabled": true,
      "serviceAccountsEnabled": false,
      "redirectUris": ["*"],
      "webOrigins": ["*"]
    }
  ],
  "users": [
    {
      "username": "alice",
      "enabled": true,
      "email": "alice@acme.local",
      "emailVerified": true,
      "firstName": "Alice",
      "lastName": "Chen",
      "credentials": [{ "type": "password", "value": "alice123", "temporary": false }],
      "realmRoles": ["sales_user"]
    },
    {
      "username": "bob",
      "enabled": true,
      "email": "bob@acme.local",
      "emailVerified": true,
      "firstName": "Bob",
      "lastName": "Martinez",
      "credentials": [{ "type": "password", "value": "bob123", "temporary": false }],
      "realmRoles": ["support_user"]
    },
    {
      "username": "dana",
      "enabled": true,
      "email": "dana@acme.local",
      "emailVerified": true,
      "firstName": "Dana",
      "lastName": "Ops",
      "credentials": [{ "type": "password", "value": "dana123", "temporary": false }],
      "realmRoles": ["operations_user"]
    },
    {
      "username": "admin",
      "enabled": true,
      "email": "admin@acme.local",
      "emailVerified": true,
      "firstName": "Alex",
      "lastName": "Admin",
      "credentials": [{ "type": "password", "value": "admin123", "temporary": false }],
      "realmRoles": ["admin"]
    }
  ]
}
